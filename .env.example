# 운영 환경에서 다시 채워야 하는 예시 파일입니다.
# 로컬 검증용 값, 특정 머신의 URL, 표시 이름을 그대로 복사하지 마세요.

OPENWEBUI_BASE_URL=https://openwebui.example.com
OPENWEBUI_BOT_TOKEN=sk_xxx

# websocket 인증은 아래 둘 중 하나를 사용합니다.
OPENWEBUI_BOT_SESSION_TOKEN=
OPENWEBUI_BOT_EMAIL=
OPENWEBUI_BOT_PASSWORD=

# 표시 이름이 아니라 실제 Open WebUI 내부 user id를 넣어야 합니다.
OPENWEBUI_BOT_USER_ID=actual-user-id
OPENWEBUI_BOT_DISPLAY_NAME=TEAM-BOT

OPENWEBUI_MODEL_ID=team-bot-model

# Open Terminal을 쓰지 않으면 비워둡니다.
# terminal connection의 URL은 Open WebUI 서버 기준으로 접근 가능해야 합니다.
OPENWEBUI_TERMINAL_ID=

# 필요 없으면 모두 비워둡니다.
OPENWEBUI_SKILL_IDS=
OPENWEBUI_TOOL_IDS=
OPENWEBUI_TOOL_SERVER_IDS=
OPENWEBUI_FEATURES_JSON=''
OPENWEBUI_FORCE_NATIVE_FUNCTION_CALLING=false

CHANNEL_CONTEXT_LIMIT=20
THREAD_CONTEXT_LIMIT=50
COMPLETION_TIMEOUT_SECONDS=60
OPENWEBUI_TOOL_TIMEOUT_SECONDS=300
OPENWEBUI_STARTUP_RETRY_SECONDS=5
STATE_RETENTION_SECONDS=604800
STATE_CLEANUP_INTERVAL_SECONDS=3600
STATE_DB_PATH=/tmp/team-bot-state.db

LOG_LEVEL=INFO
SOCKETIO_DEBUG=false
LOG_RAW_CHANNEL_EVENTS=false
LOG_MESSAGE_CONTENT=false
